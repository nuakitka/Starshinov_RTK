global_defs {
    enable_script_security
    script_user root
    router_id {{ inventory_hostname }}
}

vrrp_script chk_haproxy {
    script "/usr/local/bin/check_haproxy.sh"
    interval 2
    timeout 2
    fall 2
    rise 1
}

vrrp_instance VI_1 {
    state {{ keepalived_state }}
    interface eth0
    virtual_router_id 51
    priority {{ keepalived_priority }}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass s3cr3t42
    }

    unicast_src_ip {{ ansible_host }}
    unicast_peer {
        {{ keepalived_peer }}
    }

    virtual_ipaddress {
        {{ vip_address }}/24 dev eth0 label eth0:1
    }

    track_script {
        chk_haproxy
    }
}
